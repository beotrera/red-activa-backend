{
  "files": ["src/server.ts"],
  "include": ["src/**/*.ts"],
  "ts-node": {
    "transpileOnly": true,
    "files": true
  },
  "compilerOptions": {
    "module": "commonjs",
    "noImplicitAny": false,
    "target": "es2021",
    "lib": ["es2021", "dom"],
    "outDir": "dist",
    "rootDir": "",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "sourceMap": true,
    "moduleResolution": "node",
    "ignoreDeprecations": "5.0",
    "removeComments": true,
    "typeRoots": ["node_modules/@types"],
    "baseUrl": "src",
    "types": ["node","jest"],
    "paths": {
      "services/*": ["services/*"],
      "routes/*": ["routes/*"],
      "enums/*": ["enums/*"],
      "models/*": ["models/*"],
      "lib/*": ["lib/*"],
      "src/*": ["*"],
      "*": ["../node_modules/*", "types/*"]
    }
  },
  "exclude": ["node_modules"]
}